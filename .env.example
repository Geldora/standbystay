# RouteStack
ROUTESTACK_API_KEY=your-routestack-api-key
ROUTESTACK_API_SECRET=your-routestack-api-secret
ROUTESTACK_MCP_URL=https://mcp.routestack.ai/sse

# LLM Provider: "openai", "anthropic", or "mistral"
LLM_PROVIDER=anthropic

# OpenAI (required if LLM_PROVIDER=openai)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Mistral (required if LLM_PROVIDER=mistral)
# MISTRAL_API_KEY=your-mistral-api-key
# MISTRAL_MODEL=mistral-large-latest
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# SQLite database file path
DB_PATH=nonrev.db

# Server
PORT=3000
